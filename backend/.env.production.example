# ============================================================
# CONFIGURACIÓN DE PRODUCCIÓN — easyposweb.com
# Copia esto como .env en el servidor y completa los valores
# NUNCA subir este archivo con valores reales al repositorio
# ============================================================

DATABASE_URL=mysql+pymysql://easypos_user:TU_PASSWORD_AQUI@localhost/easyposweb

JWT_SECRET_KEY=GENERA_UNO_CON: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

EMAIL_SENDER=noreply@easyposweb.com
EMAIL_PASSWORD=TU_APP_PASSWORD
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

FRONTEND_URL=https://easyposweb.com

# Activa que FastAPI sirva el build de Vue
SERVE_FRONTEND=true
